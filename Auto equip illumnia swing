-- Toggle visibility
FloatButton.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
    FloatButton.BackgroundColor3 = MainFrame.Visible and Color3.fromRGB(96, 96, 128) or Color3.fromRGB(64, 64, 64)
end)

-- ─── Toggles ───
local function makeToggle(text, y, varName)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.88, 0, 0, 38)
    btn.Position = UDim2.new(0.06, 0, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
    btn.TextColor3 = Color3.fromRGB(240, 240, 240)
    btn.Font = Enum.Font.SourceSans
    btn.TextSize = 16
    btn.Text = text .. ": OFF"
    btn.Parent = MainFrame

    local uic = Instance.new("UICorner")
    uic.CornerRadius = UDim.new(0, 6)
    uic.Parent = btn

    btn.MouseButton1Click:Connect(function()
        _G[varName] = not _G[varName]
        btn.Text = text .. ": " .. (_G[varName] and "ON" or "OFF")
        btn.BackgroundColor3 = _G[varName] and Color3.fromRGB(0, 160, 0) or Color3.fromRGB(55, 55, 55)
    end)
end

makeToggle("Auto Equip", 40, "AutoIllumina")
makeToggle("Auto Swing", 85, "AutoSwing")

