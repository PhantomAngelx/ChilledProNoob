-- ─── Script Logic ───
local function getIllumina()
    local folder = workspace:FindFirstChild(player.Name)
    if folder then
        local item = folder:FindFirstChild("Illumina")
        if item and (item:IsA("Tool") or item:IsA("Model")) then return item end
    end
    return player.Backpack:FindFirstChild("Illumina")
end

local function equipIllumina()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildWhichIsA("Humanoid")
    if not hum then return end
    
    local item = getIllumina()
    if not item then return end

    if item:IsA("Tool") then
        item.Parent = char
        hum:EquipTool(item)
    else
        item.Parent = char
    end
end

local equipConn
local function startEquip()
    if equipConn then equipConn:Disconnect() end
    equipConn = RunService.Heartbeat:Connect(function()
        if not _G.AutoIllumina then return end
        local char = player.Character
        if char and not char:FindFirstChild("Illumina") then
            equipIllumina()
        end
    end)
end

local swingConn
local function startSwing()
    if swingConn then swingConn:Disconnect() end
    swingConn = RunService.Heartbeat:Connect(function()
        if not _G.AutoSwing then return end
        local char = player.Character
        if not char then return end
        local tool = char:FindFirstChild("Illumina")
        if tool and tool:IsA("Tool") then
            tool:Activate()
        end
    end)
end

player.CharacterAdded:Connect(function()
    task.wait(2)
    if _G.AutoIllumina then equipIllumina() end
end)

startEquip()
startSwing()

task.spawn(function()
    while task.wait(3) do
        if _G.AutoIllumina then equipIllumina() end
    end
end)

print("[Illumina GUI] Loaded - only one instance allowed")
