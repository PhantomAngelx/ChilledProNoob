local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local username = player.Name
local hrp, cashObj

local function refresh()
	local char = player.Character or player.CharacterAdded:Wait()
	hrp = char:WaitForChild("HumanoidRootPart")
	local ls = player:FindFirstChild("leaderstats") or player:WaitForChild("leaderstats")
	cashObj = ls:WaitForChild("Cash")
end

refresh()
player.CharacterAdded:Connect(function()
	task.wait(1)
	refresh()
end)

local function findPlayerBase()
	local folder = Workspace:WaitForChild("Tycoons"):WaitForChild("Tycoons")
	for _, base in ipairs(folder:GetChildren()) do
		if base:IsA("Model") then
			local entrance = base:FindFirstChild("Entrance")
			if entrance and entrance:FindFirstChild(username .. "'s Tycoon") then
				print("✅ Found base:", base.Name)
				return base
			end
		end
	end
	print("❌ No base found for", username)
	return nil
end

local base = findPlayerBase()
if not base then return end

-- ✅ Updated toNumber function
local function toNumber(v)
	if typeof(v) == "number" then return v end
	if typeof(v) == "Instance" and v.Value ~= nil then
		return toNumber(v.Value)
	end
	if typeof(v) == "string" then
		local s = v:upper():gsub("[%$,]", ""):gsub("%s+", "")
		local num, suffix = s:match("([%d%.%-]+)([KMBT]?)")
		num = tonumber(num)
		if not num then return 0 end
		local mult = 1
		if suffix == "K" then mult = 1e3
		elseif suffix == "M" then mult = 1e6
		elseif suffix == "B" then mult = 1e9
		elseif suffix == "T" then mult = 1e12 end
		return num * mult
	end
	return 0
end

local function fireTouch(part)
	if not (part and hrp) then return end
	for _, v in ipairs(part:GetChildren()) do
		if v:IsA("TouchTransmitter") then
			pcall(firetouchinterest, hrp, part, 0)
			task.wait(0.04)
			pcall(firetouchinterest, hrp, part, 1)
		end
	end
end

local function getCashParts()
	local list = {}
	for _, p in ipairs(base:GetDescendants()) do
		if p:IsA("BasePart") and p:FindFirstChildWhichIsA("TouchTransmitter") then
			local n = p.Name:lower()
			if n:find("cash") or n:find("collect") or n:find("giver") then
				table.insert(list, p)
			end
		end
	end
	print("💰 Cash parts:", #list)
	return list
end

local cashParts = getCashParts()

local function collectCash()
	for _, part in ipairs(cashParts) do
		fireTouch(part)
		task.wait(0.05)
	end
end

local function canBuy(btn, purchases)
	local priceObj = btn:FindFirstChild("Price")
	local dep = btn:FindFirstChild("Dependency")
	local head = btn:FindFirstChild("Head")
	if btn:FindFirstChild("Gamepass") then return false end
	if not (priceObj and head) then return false end
	if dep and not purchases:FindFirstChild(dep.Value) then return false end
	local price = toNumber(priceObj)
	local cash = toNumber(cashObj)
	return cash >= price
end

local function buyAll()
	local buttons = base:FindFirstChild("Buttons")
	local purchases = base:FindFirstChild("PurchasedObjects")
	if not (buttons and purchases) then return end
	local list = {}
	for _, btn in ipairs(buttons:GetChildren()) do
		if not btn:FindFirstChild("Gamepass") then
			local price = toNumber(btn:FindFirstChild("Price"))
			table.insert(list, {btn = btn, price = price})
		end
	end
	table.sort(list, function(a, b) return a.price < b.price end)
	for _, data in ipairs(list) do
		if canBuy(data.btn, purchases) then
			local head = data.btn:FindFirstChild("Head")
			if head then
				fireTouch(head)
				task.wait(0.1)
			end
		end
	end
end

print("⚙️ Auto Tycoon running for", username)
while task.wait(0.25) do
	if not hrp or not cashObj then refresh() end
	collectCash()
	buyAll()
end
