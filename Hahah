local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local PRIMARY_TOOL = "Illumina"        -- Main visible/active tool (right hand)
local SECONDARY_TOOL = "RocketLauncher" -- Secondary "rocket" tool (visible on left hand, unchanged)
local ENABLED = true

local function getTool(toolName)
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local char = LocalPlayer.Character
    if backpack then
        return backpack:FindFirstChild(toolName)
    elseif char then
        return char:FindFirstChild(toolName)
    end
    return nil
end

local function forcePrimary()
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local tool = getTool(PRIMARY_TOOL)
    if tool then
        pcall(function()
            local clone = tool:Clone()
            humanoid:EquipTool(clone)
        end)
    end
end

local function forceSecondary()
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    -- Clean up old clones
    for _, child in pairs(char:GetChildren()) do
        if child.Name == SECONDARY_TOOL .. "Clone" then
            child:Destroy()
        end
    end
    
    local tool = getTool(SECONDARY_TOOL)
    if tool then
        pcall(function()
            local clone = tool:Clone()
            clone.Name = SECONDARY_TOOL .. "Clone"
            clone.Parent = char
            
            local handle = clone:FindFirstChild("Handle") or clone:FindFirstChildOfClass("BasePart")
            if handle then
                -- No changes to transparency or size - keep original appearance
                handle.CanCollide = false
                handle.Massless = true
                handle.Anchored = false
                
                -- Weld to left arm for dual-wield (R6/R15 compatible)
                local leftArm = char:FindFirstChild("Left Arm") or char:FindFirstChild("LeftHand") or char.LeftHand
                if leftArm and leftArm:IsA("BasePart") then
                    local weld = Instance.new("WeldConstraint")
                    weld.Part0 = leftArm
                    weld.Part1 = handle
                    weld.Parent = leftArm
                    
                    -- Optional: Adjust position/rotation for better visuals
                    -- Uncomment and tweak if rocket looks off:
                    -- handle.CFrame = leftArm.CFrame * CFrame.new(0, -1, 0) * CFrame.Angles(math.rad(90), 0, 0)
                end
            end
        end)
    end
end

local function startAutoEquip()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoid = char:WaitForChild("Humanoid")
    local backpack = LocalPlayer:WaitForChild("Backpack")
    
    -- Initial equip
    forcePrimary()
    forceSecondary()
    
    -- Listen for new tools
    backpack.ChildAdded:Connect(function(child)
        if child.Name == PRIMARY_TOOL or child.Name == SECONDARY_TOOL then
            task.wait(0.1) -- Small delay for full load
            forcePrimary()
            forceSecondary()
        end
    end)
    
    -- Ultra-fast enforcement loop (fights anti-cheat/unequip)
    task.spawn(function()
        while ENABLED do
            pcall(function()
                forcePrimary()
                forceSecondary()
            end)
            task.wait(0.03)  -- \~33 checks/sec - very aggressive
        end
    end)
end

-- Respawn handler
LocalPlayer.CharacterAdded:Connect(function(char)
    char:WaitForChild("Humanoid")
    task.wait(1)  -- Extra wait for full spawn
    startAutoEquip()
end)

-- Start now
startAutoEquip()

print("🚀 Auto-Equip: Illumina (primary/right) + RocketLauncher (secondary/left, visible & unchanged) ACTIVE!")
print("💡 Buy RocketLauncher from shop if not in Backpack - script auto-detects!")
print("🔧 If rocket looks weird on left hand, uncomment CFrame line and adjust.")
print("🛠️ Change SECONDARY_TOOL if rocket has different name (e.g. 'Famas' from Dex).")
