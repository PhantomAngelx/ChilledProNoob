-- Services
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- ScreenGui
local gui = Instance.new("ScreenGui")
gui.Name = "ResetCharacterGui"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- Main Frame
local frame = Instance.new("Frame")
frame.Size = UDim2.fromScale(0.18, 0.15)
frame.Position = UDim2.fromScale(0.4, 0.4)
frame.BackgroundColor3 = Color3.fromRGB(255, 105, 180) -- Pink
frame.BackgroundTransparency = 0.25
frame.BorderSizePixel = 0
frame.Parent = gui

-- IMPORTANT FOR DRAGGING
frame.Active = true
frame.Selectable = true
frame.Draggable = true

-- Rounded corners
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0.15, 0)
corner.Parent = frame

-- Title
local title = Instance.new("TextLabel")
title.Size = UDim2.fromScale(1, 0.35)
title.BackgroundTransparency = 1
title.Text = "RC"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.Font = Enum.Font.GothamBold
title.TextScaled = true
title.Parent = frame

-- Reset Button
local button = Instance.new("TextButton")
button.Size = UDim2.fromScale(0.6, 0.4)
button.Position = UDim2.fromScale(0.2, 0.45)
button.BackgroundColor3 = Color3.fromRGB(255, 80, 160)
button.Text = "RC"
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.Font = Enum.Font.GothamBlack
button.TextScaled = true
button.Parent = frame

-- Button round
local btnCorner = Instance.new("UICorner")
btnCorner.CornerRadius = UDim.new(0.3, 0)
btnCorner.Parent = button

-- Glow effect
local glow = Instance.new("UIStroke")
glow.Color = Color3.fromRGB(255, 180, 220)
glow.Thickness = 2
glow.Transparency = 0.4
glow.Parent = button

-- Reset function
local function resetCharacter()
	local character = player.Character
	if character then
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if humanoid then
			humanoid.Health = 0
		end
	end
end

-- Button effects + reset
button.MouseButton1Down:Connect(function()
	glow.Thickness = 6
	glow.Transparency = 0
	resetCharacter()
end)

button.MouseButton1Up:Connect(function()
	glow.Thickness = 2
	glow.Transparency = 0.4
end)
