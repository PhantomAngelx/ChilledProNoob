-- 🔧 FIXED MINIMIZE / EXPAND LOGIC
toggleButton.MouseButton1Click:Connect(function()
	expanded = not expanded

	if expanded then
		scroll.Visible = true

		-- Recalculate correct height based on content
		local contentHeight = scroll.CanvasSize.Y.Offset
		local newHeight = math.clamp(30 + contentHeight, 80, 250)

		frame.Size = UDim2.new(0, 160, 0, newHeight)
		toggleButton.Text = "−"
	else
		scroll.Visible = false
		frame.Size = UDim2.new(0, 160, 0, collapsedHeight)
		toggleButton.Text = "+"
	end
end)

local selectedButtons = {}
local runningLoops = {}

local function updatePlayerButtons()
	local selectedNames = {}
	for name in pairs(selectedButtons) do
		selectedNames[name] = true
	end

	for _, child in ipairs(scroll:GetChildren()) do
		if child:IsA("TextButton") then
			child:Destroy()
		end
	end

	local players = Players:GetPlayers()
	local y = 0
	for _, plr in ipairs(players) do
		if plr ~= LocalPlayer then
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1, -8, 0, 20)
			btn.Position = UDim2.new(0, 4, 0, y)
			btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
			btn.TextColor3 = Color3.new(1, 1, 1)
			btn.Font = Enum.Font.SourceSans
			btn.TextSize = 14
			btn.Text = plr.Name
			btn.BorderSizePixel = 0
			btn.Parent = scroll

			local key = plr.Name
			if selectedNames[key] then
				btn.BackgroundColor3 = Color3.fromRGB(130, 80, 180)
				selectedButtons[key] = btn
			end

			btn.MouseButton1Click:Connect(function()
				if selectedButtons[key] then
					btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
					selectedButtons[key] = nil

					if runningLoops[key] then
						pcall(runningLoops[key])
						runningLoops[key] = nil
					end
				else
					btn.BackgroundColor3 = Color3.fromRGB(130, 80, 180)
					selectedButtons[key] = btn

					if not runningLoops[key] then
						local stopFn = startHandleKillLoop(plr, math.huge)
						if stopFn then
							runningLoops[key] = stopFn
						else
							btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
							selectedButtons[key] = nil
						end
					end
				end
			end)

			y = y + 21
		end
	end

	scroll.CanvasSize = UDim2.new(0, 0, 0, y)

	-- Resize only when expanded
	if expanded then
		frame.Size = UDim2.new(0, 160, 0, math.clamp(30 + y, 80, 250))
	end
end

updatePlayerButtons()

Players.PlayerAdded:Connect(updatePlayerButtons)
Players.PlayerRemoving:Connect(function(plr)
	local key = plr.Name
	if runningLoops[key] then
		pcall(runningLoops[key])
		runningLoops[key] = nil
	end
	selectedButtons[key] = nil
	updatePlayerButtons()
end)

LocalPlayer.CharacterRemoving:Connect(function()
	for _, stopfn in pairs(runningLoops) do pcall(stopfn) end
	runningLoops = {}
	selectedButtons = {}
	updatePlayerButtons()
end)
