-- Spam Button
local spamButton = createButton(pages[1], "Spam", 20)
spamButton.MouseButton1Click:Connect(function()
    local numTotalRockets = 50000
    local batchSize = 5000
    local maxPing = 450
    local eventDelay = 0.001

    local Players = game:GetService("Players")  
    local LocalPlayer = Players.LocalPlayer  

    local function getPing()  
        local stats = LocalPlayer:GetNetworkPing()  
        return stats and math.floor(stats * 1000) or 0  
    end  

    local launcher  
    repeat  
        launcher = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("RocketLauncher")  
        if not launcher then task.wait(0.2) end  
    until launcher  

    local rocketEvent = launcher:FindFirstChild("BattleRocketEvent")  
    assert(rocketEvent, "No RocketLauncher event found!")  

    local function launchBatch()  
        local launched = 0  
        while launched < numTotalRockets do  
            for i = 1, batchSize do  
                local target = Vector3.new(  
                    math.random(-1000, 1000),  
                    math.random(0, 1000),  
                    math.random(-1000, 1000)  
                )  
                pcall(function()  
                    rocketEvent:FireServer(target)  
                end)  
                launched = launched + 1  
                if launched >= numTotalRockets then break end  
            end  
            local currentPing = getPing()  
            task.wait(currentPing > maxPing and eventDelay*3 or eventDelay)  
        end  
    end  

    while true do  
        launchBatch()  
        task.wait(2)  
    end
end)

