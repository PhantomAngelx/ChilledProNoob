createButton(pages[2], "Serverhop", 60).MouseButton1Click:Connect(function()
    local HttpService = game:GetService("HttpService")
    local Servers = game:HttpGetAsync("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100")
    local ServerData = HttpService:JSONDecode(Servers).data
    local bestServer
    local maxPlayers = 0
    for _, v in ipairs(ServerData) do
        if type(v)=="table" and v.maxPlayers>v.playing and v.id~=game.JobId then
            if v.playing>maxPlayers then
                maxPlayers=v.playing
                bestServer=v.id
            end
        end
    end
    if bestServer then
        game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, bestServer)
    end
end)

