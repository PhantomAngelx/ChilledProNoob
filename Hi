    local titleLabel = Instance.new("TextLabel")  
    titleLabel.Name = "Label"  
    titleLabel.Parent = mainFrameBH  
    titleLabel.BackgroundColor3 = Color3.fromRGB(95, 95, 95)  
    titleLabel.BorderSizePixel = 0  
    titleLabel.Size = UDim2.new(1, 0, 0.16, 0)  
    titleLabel.Text = "Blackhole | BR"  
    titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)  
    titleLabel.TextScaled = true  
    titleLabel.TextWrapped = true  

    local bringButton = Instance.new("TextButton")  
    bringButton.Name = "Button"  
    bringButton.Parent = mainFrameBH  
    bringButton.BackgroundColor3 = Color3.fromRGB(95, 95, 95)  
    bringButton.BorderSizePixel = 0  
    bringButton.Position = UDim2.new(0.18, 0, 0.66, 0)  
    bringButton.Size = UDim2.new(0.63, 0, 0.28, 0)  
    bringButton.Font = Enum.Font.Nunito  
    bringButton.Text = "Bring | Off"  
    bringButton.TextColor3 = Color3.fromRGB(255, 255, 255)  
    bringButton.TextScaled = true  
    bringButton.TextWrapped = true  

    -- Blackhole Logic  
    local Players = game:GetService("Players")  
    local RunService = game:GetService("RunService")  
    local Workspace = game:GetService("Workspace")  
    local LocalPlayer = Players.LocalPlayer  

    local bringFolder = Instance.new("Folder", Workspace)  
    local targetPart = Instance.new("Part", bringFolder)  
    targetPart.Anchored = true  
    targetPart.CanCollide = false  
    targetPart.Transparency = 1  
    local bringAttachment = Instance.new("Attachment", targetPart)  

    if not getgenv().Network then  
        getgenv().Network = {BaseParts={}, Velocity=Vector3.new(14.46,14.46,14.46)}  
        Network.RetainPart = function(part)  
            if part:IsA("BasePart") and part:IsDescendantOf(Workspace) then  
                table.insert(Network.BaseParts, part)  
                part.CustomPhysicalProperties = PhysicalProperties.new(0,0,0,0,0)  
                part.CanCollide = false  
            end  
        end  
        RunService.Heartbeat:Connect(function()  
            sethiddenproperty(LocalPlayer, "SimulationRadius", math.huge)  
            for _, part in pairs(Network.BaseParts) do  
                if part:IsDescendantOf(Workspace) then  
                    part.Velocity = Network.Velocity  
                end  
            end  
        end)  
    end  

    local isBringing = false  
    local bringConnection  
    local targetChar  
    local targetHRP  

    local function attachToBlackHole(part)  
        if part:IsA("Part") and part.Name == "Rocket" and part.Parent == Workspace and not part.Anchored then  
            for _, child in ipairs(part:GetChildren()) do  
                if child:IsA("BodyMover") or child:IsA("RocketPropulsion") then  
                    child:Destroy()  
                end  
            end  
            if part:FindFirstChild("Attachment") then part.Attachment:Destroy() end  
            if part:FindFirstChild("AlignPosition") then part.AlignPosition:Destroy() end  
            if part:FindFirstChild("Torque") then part.Torque:Destroy() end  
            part.CanCollide = true  

            local torque = Instance.new("Torque", part)  
            torque.Torque = Vector3.new(500000,500000,500000)  
            local alignPos = Instance.new("AlignPosition", part)  
            local attach = Instance.new("Attachment", part)  
            torque.Attachment0 = attach  
            alignPos.MaxForce = math.huge  
            alignPos.MaxVelocity = math.huge  
            alignPos.Responsiveness = 500  
            alignPos.Attachment0 = attach  
            alignPos.Attachment1 = bringAttachment  
        end  
    end  

    local function startBringing()  
        for _, obj in ipairs(Workspace:GetDescendants()) do attachToBlackHole(obj) end  
        bringConnection = Workspace.DescendantAdded:Connect(function(obj)  
            if isBringing then attachToBlackHole(obj) end  
        end)  
        spawn(function()  
            while isBringing and RunService.RenderStepped:Wait() do  
                if targetHRP then  
                    bringAttachment.WorldCFrame = targetHRP.CFrame  
                end  
            end  
        end)  
    end  

    local function toggleBringing()  
        isBringing = not isBringing  
        bringButton.Text = isBringing and "Bring Parts | On" or "Bring Parts | Off"  
        if isBringing then  
            startBringing()  
        else  
            if bringConnection then bringConnection:Disconnect() end  
        end  
    end  

    local function findPlayer(name)  
        name = string.lower(name)  
        for _, plr in pairs(Players:GetPlayers()) do  
            if string.find(string.lower(plr.Name), name) or string.find(string.lower(plr.DisplayName), name) then  
                return plr  
            end  
        end  
    end  

    inputBox.FocusLost:Connect(function(enterPressed)  
        if enterPressed then  
            local selectedPlayer = findPlayer(inputBox.Text)  
            if selectedPlayer then  
                inputBox.Text = selectedPlayer.Name  
                local function setTarget(char)  
                    targetChar = char  
                    targetHRP = char:WaitForChild("HumanoidRootPart")  
                end  
                setTarget(selectedPlayer.Character or selectedPlayer.CharacterAdded:Wait())  
                selectedPlayer.CharacterAdded:Connect(setTarget)  
            end  
        end  
    end)  

    bringButton.MouseButton1Click:Connect(function()  
        if targetHRP then toggleBringing() end  
    end)
end)

-- Auto Equip Button
local autoEquipButton = createButton(pages[1], "Auto Equip", 100)
autoEquipButton.MouseButton1Click:Connect(function()
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer

    local TOOL_NAME = "RocketLauncher"  
    local ENABLED = true  

    local function equipTool(tool)  
        local character = LocalPlayer.Character  
        if character then  
            local humanoid = character:FindFirstChildOfClass("Humanoid")  
            if humanoid and tool then  
                pcall(function()  
                    humanoid:EquipTool(tool)  
                end)  
            end  
        end  
    end  

    local function startAutoEquip()  
        local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()  
        local backpack = LocalPlayer:WaitForChild("Backpack")  

        local tool = backpack:FindFirstChild(TOOL_NAME)  
        if tool then  
            equipTool(tool)  
        end  

        backpack.ChildAdded:Connect(function(child)  
            if child.Name == TOOL_NAME then  
                equipTool(child)  
            end  
        end)  

        task.spawn(function()  
            while ENABLED do  
                local char = LocalPlayer.Character  
                if char then  
                    local humanoid = char:FindFirstChildOfClass("Humanoid")  
                    local equippedTool = humanoid and humanoid:FindFirstChildOfClass("Tool")  
                    local rocket = backpack:FindFirstChild(TOOL_NAME) or char:FindFirstChild(TOOL_NAME)  
                    if rocket and (not equippedTool or equippedTool.Name ~= TOOL_NAME) then  
                        equipTool(rocket)  
                    end  
                end  
                task.wait(0.05)  
            end  
        end)  
    end  

    LocalPlayer.CharacterAdded:Connect(function(character)  
        character:WaitForChild("Humanoid")  
        startAutoEquip()  
    end)  

    startAutoEquip()
end)

